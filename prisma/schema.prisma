generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  TOUR_OPERATOR
  ADMIN
}

enum ExcursionCategory {
  SNORKELING
  DIVING
  ISLAND_EXPERIENCE
  FISHING
  WATER_SPORTS
  CULTURAL
}

enum Difficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          Role      @default(CUSTOMER)
  phone         String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  bookings Booking[]
  reviews  Review[]
  favorites Favorite[]
  points Int @default(0)
  pointsTransactions PointsTransaction[]
}

model Excursion {
  id             String            @id @default(cuid())
  title          String
  slug           String            @unique
  description    String
  shortDesc      String
  category       ExcursionCategory
  duration       Int
  maxCapacity    Int
  pricePerPerson Decimal           @db.Decimal(10, 2)
  groupDiscount  Decimal?          @db.Decimal(5, 2)
  included       String[]
  excluded       String[]
  meetingPoint   String
  difficulty     Difficulty
  minAge         Int?
  blackoutDates  DateTime[]         @default([])
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  images   ExcursionImage[]
  bookings Booking[]
  reviews  Review[]
  favorites Favorite[]

  @@index([category])
  @@index([isActive])
  @@index([slug])
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  excursionId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  excursion Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@unique([userId, excursionId])
  @@index([userId])
}

model PointsTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  type      String
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Analytics {
  id          String   @id @default(cuid())
  event       String
  excursionId String?
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([event])
  @@index([excursionId])
  @@index([createdAt])
}

model ExcursionImage {
  id         String    @id @default(cuid())
  excursionId String
  url        String
  altText    String
  isPrimary  Boolean   @default(false)
  order      Int       @default(0)

  excursion Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)
}

model Booking {
  id              String        @id @default(cuid())
  bookingNumber   String        @unique
  userId          String
  excursionId     String
  bookingDate     DateTime
  participants    Int
  totalPrice      Decimal       @db.Decimal(10, 2)
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentIntentId String?
  specialRequests String?
  customerName    String
  customerEmail   String
  customerPhone   String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  excursion Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([excursionId])
  @@index([bookingDate])
  @@index([status])
}

model Review {
  id         String   @id @default(cuid())
  excursionId String
  userId     String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  excursion Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([excursionId, userId])
}

model Settings {
  id                  String @id @default(cuid())
  businessName        String
  businessEmail       String
  businessPhone       String
  currency            String @default("USD")
  timezone            String @default("Indian/Maldives")
  bookingLeadTime     Int    @default(24)
  cancellationPolicy  String
  termsAndConditions  String
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
